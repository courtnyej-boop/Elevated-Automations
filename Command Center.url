<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Command Center</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #080810;
  --surface: #0e0e1a;
  --surface2: #141424;
  --border: rgba(255,255,255,0.06);
  --border2: rgba(255,255,255,0.12);
  --accent: #00e5ff;
  --accent2: #7c3aff;
  --green: #00ff88;
  --amber: #ffaa00;
  --red: #ff3355;
  --text: #f0f0f8;
  --muted: rgba(240,240,248,0.45);
  --muted2: rgba(240,240,248,0.25);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--text);font-family:'Space Grotesk',sans-serif;display:flex;flex-direction:column;}

/* TOPBAR */
.topbar{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 24px;
  border-bottom:1px solid var(--border);
  background:rgba(8,8,16,0.9);
  backdrop-filter:blur(20px);
  flex-shrink:0;
  position:relative;z-index:10;
}
.logo{
  font-family:'JetBrains Mono',monospace;
  font-size:0.85rem;font-weight:500;letter-spacing:0.12em;
  color:var(--text);
  display:flex;align-items:center;gap:10px;
}
.logo-dot{
  width:8px;height:8px;border-radius:50%;
  background:var(--accent);
  box-shadow:0 0 8px var(--accent);
  animation:blink 2s infinite;
}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.4;}}
.topbar-center{
  display:flex;align-items:center;gap:24px;
  font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;
  color:var(--muted);
}
.status-pill{
  display:flex;align-items:center;gap:6px;
  padding:4px 12px;
  border:1px solid rgba(0,229,255,0.2);
  border-radius:20px;
  font-size:0.65rem;letter-spacing:0.14em;
  color:var(--accent);
}
.status-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);animation:blink 1.5s infinite;}
.topbar-right{display:flex;align-items:center;gap:12px;}
.icon-btn{
  width:34px;height:34px;border-radius:8px;
  background:transparent;border:1px solid var(--border2);
  color:var(--muted);cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.2s;font-size:14px;
}
.icon-btn:hover{border-color:var(--accent);color:var(--accent);}
.settings-btn{
  padding:6px 16px;border-radius:8px;
  background:transparent;border:1px solid var(--border2);
  color:var(--muted);cursor:pointer;
  font-family:inherit;font-size:0.7rem;letter-spacing:0.1em;
  text-transform:uppercase;transition:all 0.2s;
}
.settings-btn:hover{border-color:var(--accent);color:var(--accent);}

/* MAIN LAYOUT */
.main{display:flex;flex:1;overflow:hidden;}

/* LEFT SIDEBAR */
.sidebar{
  width:220px;flex-shrink:0;
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;
  overflow:hidden;
  background:var(--surface);
}
.sidebar-section{padding:16px 16px 8px;}
.sidebar-label{
  font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;
  color:var(--muted2);margin-bottom:10px;
}
.agent-item{
  display:flex;align-items:center;gap:10px;
  padding:8px 12px;border-radius:8px;
  cursor:pointer;transition:all 0.15s;
  margin-bottom:2px;
}
.agent-item:hover{background:var(--surface2);}
.agent-item.active{background:rgba(0,229,255,0.08);border:1px solid rgba(0,229,255,0.15);}
.agent-dot{
  width:7px;height:7px;border-radius:50%;flex-shrink:0;
}
.dot-online{background:var(--green);box-shadow:0 0 6px var(--green);}
.dot-idle{background:var(--amber);}
.dot-offline{background:var(--muted2);}
.agent-name{font-size:0.78rem;font-weight:500;color:var(--text);}
.agent-squad{font-size:0.62rem;color:var(--muted2);}
.sidebar-divider{height:1px;background:var(--border);margin:8px 0;}

/* MAIN CHAT AREA */
.chat-area{
  flex:1;display:flex;flex-direction:column;overflow:hidden;
}

/* MISSION RIBBON */
.mission-ribbon{
  display:flex;align-items:center;gap:12px;
  padding:10px 24px;
  border-bottom:1px solid var(--border);
  background:var(--surface);
  flex-shrink:0;overflow-x:auto;
  scrollbar-width:none;
}
.mission-ribbon::-webkit-scrollbar{display:none;}
.mission-chip{
  display:flex;align-items:center;gap:7px;
  padding:5px 12px;border-radius:6px;
  background:var(--surface2);border:1px solid var(--border);
  font-size:0.65rem;letter-spacing:0.08em;
  color:var(--muted);white-space:nowrap;cursor:pointer;
  transition:all 0.15s;flex-shrink:0;
}
.mission-chip:hover{border-color:var(--accent);color:var(--accent);}
.mission-chip.running{
  border-color:rgba(0,229,255,0.3);
  color:var(--accent);
  background:rgba(0,229,255,0.06);
}
.chip-dot{width:5px;height:5px;border-radius:50%;}
.chip-dot.running{background:var(--accent);animation:blink 1s infinite;}
.chip-dot.done{background:var(--green);}
.chip-dot.idle{background:var(--muted2);}

/* MESSAGES */
.messages{
  flex:1;overflow-y:auto;
  padding:24px;
  scrollbar-width:thin;scrollbar-color:var(--border2) transparent;
  display:flex;flex-direction:column;gap:20px;
}
.messages::-webkit-scrollbar{width:4px;}
.messages::-webkit-scrollbar-thumb{background:var(--border2);}

.msg{display:flex;gap:14px;animation:msgIn 0.3s ease;}
@keyframes msgIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

.msg-avatar{
  width:32px;height:32px;border-radius:8px;
  flex-shrink:0;display:flex;align-items:center;justify-content:center;
  font-size:12px;font-weight:600;letter-spacing:0.05em;
  margin-top:2px;
}
.avatar-you{background:rgba(124,58,255,0.2);color:#a78bfa;border:1px solid rgba(124,58,255,0.3);}
.avatar-cmd{background:rgba(0,229,255,0.15);color:var(--accent);border:1px solid rgba(0,229,255,0.25);}
.avatar-agent{background:rgba(0,255,136,0.1);color:var(--green);border:1px solid rgba(0,255,136,0.2);}

.msg-body{flex:1;min-width:0;}
.msg-header{display:flex;align-items:center;gap:10px;margin-bottom:5px;}
.msg-name{font-size:0.75rem;font-weight:600;color:var(--text);}
.msg-time{font-size:0.65rem;color:var(--muted2);}
.msg-badge{
  font-size:0.58rem;letter-spacing:0.12em;text-transform:uppercase;
  padding:2px 7px;border-radius:4px;
}
.badge-cmd{background:rgba(0,229,255,0.1);color:var(--accent);border:1px solid rgba(0,229,255,0.2);}
.badge-agent{background:rgba(0,255,136,0.08);color:var(--green);border:1px solid rgba(0,255,136,0.15);}
.badge-you{background:rgba(124,58,255,0.1);color:#a78bfa;border:1px solid rgba(124,58,255,0.2);}

.msg-text{
  font-size:0.85rem;line-height:1.65;color:var(--text);
  background:var(--surface);border:1px solid var(--border);
  border-radius:0 12px 12px 12px;padding:12px 16px;
  max-width:680px;
}
.msg.you .msg-text{
  background:rgba(124,58,255,0.08);
  border-color:rgba(124,58,255,0.2);
  border-radius:12px 0 12px 12px;
}

/* Task list inside message */
.task-list{margin-top:10px;display:flex;flex-direction:column;gap:6px;}
.task-item{
  display:flex;align-items:center;gap:10px;
  padding:7px 12px;border-radius:8px;
  background:var(--surface2);border:1px solid var(--border);
  font-size:0.78rem;
}
.task-icon{font-size:11px;width:16px;text-align:center;}
.task-name{flex:1;color:var(--text);}
.task-status{font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;}
.task-done{color:var(--green);}
.task-running{color:var(--accent);}
.task-pending{color:var(--muted2);}

/* Code block */
.code-block{
  margin-top:10px;
  background:rgba(0,0,0,0.4);border:1px solid var(--border2);
  border-radius:8px;overflow:hidden;
}
.code-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:6px 12px;border-bottom:1px solid var(--border);
}
.code-lang{font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted2);}
.code-copy{
  font-size:0.62rem;letter-spacing:0.1em;text-transform:uppercase;
  color:var(--accent);background:transparent;border:none;cursor:pointer;
  font-family:inherit;
}
.code-body{
  padding:14px;
  font-family:'JetBrains Mono',monospace;font-size:0.75rem;
  line-height:1.7;color:#a8e6cf;overflow-x:auto;
  white-space:pre;
}

/* KPI row */
.kpi-row{
  display:flex;gap:10px;margin-top:12px;flex-wrap:wrap;
}
.kpi-card{
  flex:1;min-width:100px;
  padding:12px 14px;border-radius:10px;
  background:var(--surface2);border:1px solid var(--border);
}
.kpi-num{
  font-family:'JetBrains Mono',monospace;
  font-size:1.5rem;font-weight:500;
  color:var(--accent);line-height:1;margin-bottom:4px;
}
.kpi-label{font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);}

/* INPUT AREA */
.input-area{
  padding:16px 24px;
  border-top:1px solid var(--border);
  background:var(--surface);flex-shrink:0;
}
.input-wrap{
  display:flex;align-items:flex-end;gap:10px;
  background:var(--surface2);
  border:1px solid var(--border2);
  border-radius:12px;padding:10px 14px;
  transition:border-color 0.2s;
}
.input-wrap:focus-within{border-color:rgba(0,229,255,0.4);}
.cmd-input{
  flex:1;background:transparent;border:none;outline:none;
  color:var(--text);font-family:inherit;font-size:0.88rem;
  line-height:1.5;resize:none;min-height:24px;max-height:120px;
}
.cmd-input::placeholder{color:var(--muted2);}
.input-actions{display:flex;gap:8px;align-items:center;}
.mic-input-btn{
  width:34px;height:34px;border-radius:8px;
  background:transparent;border:1px solid var(--border2);
  color:var(--muted);cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.2s;
}
.mic-input-btn:hover{border-color:var(--accent);color:var(--accent);}
.mic-input-btn.recording{
  background:rgba(255,51,85,0.15);border-color:var(--red);color:var(--red);
}
.send-btn{
  width:34px;height:34px;border-radius:8px;
  background:var(--accent);border:none;color:var(--bg);
  cursor:pointer;display:flex;align-items:center;justify-content:center;
  transition:all 0.2s;
}
.send-btn:hover{box-shadow:0 0 20px rgba(0,229,255,0.4);transform:scale(1.05);}
.send-btn:disabled{background:var(--border2);color:var(--muted2);cursor:not-allowed;transform:none;box-shadow:none;}
.input-footer{
  display:flex;align-items:center;justify-content:space-between;
  margin-top:8px;
  font-size:0.62rem;color:var(--muted2);letter-spacing:0.08em;
}
.quick-cmds{display:flex;gap:8px;flex-wrap:wrap;}
.quick-cmd{
  padding:3px 10px;border-radius:4px;
  background:var(--surface2);border:1px solid var(--border);
  font-size:0.62rem;color:var(--muted);cursor:pointer;
  transition:all 0.15s;white-space:nowrap;
}
.quick-cmd:hover{border-color:var(--accent);color:var(--accent);}

/* RIGHT PANEL */
.right-panel{
  width:280px;flex-shrink:0;
  border-left:1px solid var(--border);
  display:flex;flex-direction:column;
  background:var(--surface);overflow-y:auto;
  scrollbar-width:none;
}
.right-panel::-webkit-scrollbar{display:none;}
.panel-section{padding:16px;}
.panel-title{
  font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;
  color:var(--muted2);margin-bottom:12px;
  display:flex;align-items:center;justify-content:space-between;
}
.pipeline-item{
  padding:10px 12px;border-radius:8px;
  background:var(--surface2);border:1px solid var(--border);
  margin-bottom:8px;
}
.pipeline-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.pipeline-name{font-size:0.78rem;font-weight:500;}
.pipeline-badge{
  font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;
  padding:2px 8px;border-radius:4px;
}
.pb-live{background:rgba(0,255,136,0.1);color:var(--green);}
.pb-paused{background:rgba(255,170,0,0.1);color:var(--amber);}
.pb-building{background:rgba(0,229,255,0.1);color:var(--accent);}
.pipeline-meta{font-size:0.68rem;color:var(--muted);}
.progress-bar{
  height:3px;background:var(--border2);border-radius:2px;
  margin-top:8px;overflow:hidden;
}
.progress-fill{
  height:100%;border-radius:2px;
  background:linear-gradient(90deg, var(--accent), var(--accent2));
  transition:width 0.5s ease;
}
.activity-item{
  display:flex;gap:10px;margin-bottom:10px;
  font-size:0.75rem;line-height:1.5;
}
.activity-time{color:var(--muted2);flex-shrink:0;font-size:0.65rem;font-family:'JetBrains Mono',monospace;}
.activity-text{color:var(--muted);}
.activity-text strong{color:var(--text);font-weight:500;}

/* SETTINGS MODAL */
.modal{
  position:fixed;inset:0;
  background:rgba(0,0,0,0.7);backdrop-filter:blur(20px);
  z-index:200;display:none;align-items:center;justify-content:center;padding:24px;
}
.modal.open{display:flex;}
.modal-card{
  background:var(--surface);border:1px solid var(--border2);
  border-radius:16px;padding:32px;
  max-width:520px;width:100%;max-height:80vh;overflow-y:auto;
}
.modal-title{
  font-size:1.2rem;font-weight:600;margin-bottom:4px;
}
.modal-sub{font-size:0.8rem;color:var(--muted);line-height:1.6;margin-bottom:24px;}
.field{margin-bottom:16px;}
.field label{
  display:block;font-size:0.62rem;letter-spacing:0.18em;
  text-transform:uppercase;color:var(--muted);margin-bottom:6px;
}
.field input,.field textarea{
  width:100%;padding:10px 14px;
  background:var(--surface2);border:1px solid var(--border2);
  color:var(--text);font-family:inherit;font-size:0.82rem;
  border-radius:8px;transition:border-color 0.2s;
}
.field input:focus,.field textarea:focus{outline:none;border-color:var(--accent);}
.modal-actions{display:flex;gap:10px;margin-top:20px;}
.btn-save{
  flex:1;padding:11px;border-radius:8px;
  background:var(--accent);border:none;color:var(--bg);
  font-family:inherit;font-size:0.75rem;font-weight:600;
  letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;
  transition:all 0.2s;
}
.btn-save:hover{box-shadow:0 0 24px rgba(0,229,255,0.4);}
.btn-cancel{
  padding:11px 20px;border-radius:8px;
  background:transparent;border:1px solid var(--border2);
  color:var(--muted);font-family:inherit;font-size:0.75rem;
  letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;
  transition:all 0.2s;
}
.btn-cancel:hover{border-color:var(--text);color:var(--text);}

/* TYPING INDICATOR */
.typing{display:flex;gap:4px;align-items:center;padding:4px 0;}
.typing span{
  width:6px;height:6px;border-radius:50%;background:var(--accent);
  animation:typing 1.2s infinite;
}
.typing span:nth-child(2){animation-delay:0.2s;}
.typing span:nth-child(3){animation-delay:0.4s;}
@keyframes typing{0%,80%,100%{transform:scale(0.6);opacity:0.4;}40%{transform:scale(1);opacity:1;}}

/* Scrollbar */
.messages::-webkit-scrollbar-track{background:transparent;}
</style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <div class="logo">
    <div class="logo-dot"></div>
    CMD // CONTROL
  </div>
  <div class="topbar-center">
    <div class="status-pill">
      <div class="status-dot"></div>
      Army online · 11 agents
    </div>
    <span id="clock" style="font-family:'JetBrains Mono',monospace;font-size:0.72rem;"></span>
  </div>
  <div class="topbar-right">
    <button class="icon-btn" title="Voice command" onclick="toggleVoice()" id="voiceTopBtn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
    </button>
    <button class="settings-btn" onclick="openSettings()">Configure</button>
  </div>
</div>

<!-- MAIN -->
<div class="main">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sidebar-section">
      <div class="sidebar-label">Build squad</div>
      <div class="agent-item active" onclick="selectAgent(this,'Architect')">
        <div class="agent-dot dot-online"></div>
        <div><div class="agent-name">Architect</div><div class="agent-squad">Design workflows</div></div>
      </div>
      <div class="agent-item" onclick="selectAgent(this,'Builder')">
        <div class="agent-dot dot-online"></div>
        <div><div class="agent-name">Builder</div><div class="agent-squad">Generate n8n JSON</div></div>
      </div>
      <div class="agent-item" onclick="selectAgent(this,'Debugger')">
        <div class="agent-dot dot-idle"></div>
        <div><div class="agent-name">Debugger</div><div class="agent-squad">Fix errors</div></div>
      </div>
    </div>

    <div class="sidebar-divider"></div>

    <div class="sidebar-section">
      <div class="sidebar-label">Ops squad</div>
      <div class="agent-item" onclick="selectAgent(this,'Lead Finder')">
        <div class="agent-dot dot-online"></div>
        <div><div class="agent-name">Lead Finder</div><div class="agent-squad">Apollo · Clay</div></div>
      </div>
      <div class="agent-item" onclick="selectAgent(this,'Scorer')">
        <div class="agent-dot dot-online"></div>
        <div><div class="agent-name">Scorer</div><div class="agent-squad">0–100 qualify</div></div>
      </div>
      <div class="agent-item" onclick="selectAgent(this,'Copywriter')">
        <div class="agent-dot dot-online"></div>
        <div><div class="agent-name">Copywriter</div><div class="agent-squad">Claude API</div></div>
      </div>
    </div>

    <div class="sidebar-divider"></div>

    <div class="sidebar-section">
      <div class="sidebar-label">Outreach squad</div>
      <div class="agent-item" onclick="selectAgent(this,'Email Agent')">
        <div class="agent-dot dot-online"></div>
        <div><div class="agent-name">Email Agent</div><div class="agent-squad">Instantly</div></div>
      </div>
      <div class="agent-item" onclick="selectAgent(this,'LinkedIn Agent')">
        <div class="agent-dot dot-idle"></div>
        <div><div class="agent-name">LinkedIn Agent</div><div class="agent-squad">Phantombuster</div></div>
      </div>
      <div class="agent-item" onclick="selectAgent(this,'Voice Agent')">
        <div class="agent-dot dot-online"></div>
        <div><div class="agent-name">Voice Agent</div><div class="agent-squad">ElevenLabs</div></div>
      </div>
    </div>

    <div class="sidebar-divider"></div>

    <div class="sidebar-section">
      <div class="sidebar-label">Support squad</div>
      <div class="agent-item" onclick="selectAgent(this,'Watchdog')">
        <div class="agent-dot dot-online"></div>
        <div><div class="agent-name">Watchdog</div><div class="agent-squad">Monitor all</div></div>
      </div>
      <div class="agent-item" onclick="selectAgent(this,'Reporter')">
        <div class="agent-dot dot-online"></div>
        <div><div class="agent-name">Reporter</div><div class="agent-squad">Daily digest</div></div>
      </div>
    </div>
  </div>

  <!-- CHAT -->
  <div class="chat-area">

    <!-- MISSION RIBBON -->
    <div class="mission-ribbon">
      <div class="mission-chip running">
        <div class="chip-dot running"></div>
        Lead Gen Pipeline
      </div>
      <div class="mission-chip">
        <div class="chip-dot done"></div>
        Agency Website
      </div>
      <div class="mission-chip">
        <div class="chip-dot done"></div>
        Voice Agent
      </div>
      <div class="mission-chip">
        <div class="chip-dot idle"></div>
        Email Sequences
      </div>
      <div class="mission-chip">
        <div class="chip-dot idle"></div>
        LinkedIn Automation
      </div>
      <div class="mission-chip">
        <div class="chip-dot idle"></div>
        ElevenLabs Calling
      </div>
    </div>

    <!-- MESSAGES -->
    <div class="messages" id="messages">

      <!-- Welcome message -->
      <div class="msg">
        <div class="msg-avatar avatar-cmd">CC</div>
        <div class="msg-body">
          <div class="msg-header">
            <span class="msg-name">Command Center</span>
            <span class="msg-badge badge-cmd">System</span>
            <span class="msg-time">Now</span>
          </div>
          <div class="msg-text">
            Command Center online. All 11 agents standing by.
            <div class="kpi-row">
              <div class="kpi-card"><div class="kpi-num" id="kpi-leads">0</div><div class="kpi-label">Leads today</div></div>
              <div class="kpi-card"><div class="kpi-num" id="kpi-hot">0</div><div class="kpi-label">HOT leads</div></div>
              <div class="kpi-card"><div class="kpi-num" id="kpi-sent">0</div><div class="kpi-label">Emails sent</div></div>
              <div class="kpi-card"><div class="kpi-num" id="kpi-booked">0</div><div class="kpi-label">Meetings</div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Example dispatch -->
      <div class="msg">
        <div class="msg-avatar avatar-cmd">CC</div>
        <div class="msg-body">
          <div class="msg-header">
            <span class="msg-name">Command Center</span>
            <span class="msg-badge badge-cmd">Dispatch</span>
            <span class="msg-time">Ready</span>
          </div>
          <div class="msg-text">
            Give me a command and I'll dispatch the right agents. Try something like "find 25 SaaS leads" or "run the lead pipeline" or "show me today's report."
            <div class="task-list">
              <div class="task-item">
                <span class="task-icon">⬡</span>
                <span class="task-name">Understand your request</span>
                <span class="task-status task-done">Ready</span>
              </div>
              <div class="task-item">
                <span class="task-icon">⬡</span>
                <span class="task-name">Pick the right agents</span>
                <span class="task-status task-done">Ready</span>
              </div>
              <div class="task-item">
                <span class="task-icon">⬡</span>
                <span class="task-name">Execute and report back</span>
                <span class="task-status task-done">Ready</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- INPUT -->
    <div class="input-area">
      <div class="input-wrap">
        <textarea class="cmd-input" id="cmdInput" placeholder="Give the army a command..." rows="1"
          onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
        <div class="input-actions">
          <button class="mic-input-btn" id="micBtn" onclick="toggleVoice()" title="Hold to speak">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
          </button>
          <button class="send-btn" id="sendBtn" onclick="sendCommand()" title="Send command (Enter)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </div>
      </div>
      <div class="input-footer">
        <div class="quick-cmds">
          <div class="quick-cmd" onclick="setCmd('Find 25 SaaS leads in fintech')">Find leads</div>
          <div class="quick-cmd" onclick="setCmd('Run the full lead gen pipeline')">Run pipeline</div>
          <div class="quick-cmd" onclick="setCmd('Show me today\\'s pipeline report')">Today\\'s report</div>
          <div class="quick-cmd" onclick="setCmd('Write outreach copy for hot leads')">Write copy</div>
          <div class="quick-cmd" onclick="setCmd('What agents are currently running?')">Agent status</div>
        </div>
        <span>Enter to send · Shift+Enter for new line</span>
      </div>
    </div>

  </div>

  <!-- RIGHT PANEL -->
  <div class="right-panel">
    <div class="panel-section">
      <div class="panel-title">
        <span>Active pipelines</span>
        <span style="color:var(--accent);font-size:0.65rem;">3</span>
      </div>

      <div class="pipeline-item">
        <div class="pipeline-header">
          <span class="pipeline-name">Lead Gen Pipeline</span>
          <span class="pipeline-badge pb-live">Live</span>
        </div>
        <div class="pipeline-meta">Next run: 8:00 AM tomorrow</div>
        <div class="progress-bar"><div class="progress-fill" style="width:75%"></div></div>
      </div>

      <div class="pipeline-item">
        <div class="pipeline-header">
          <span class="pipeline-name">Voice Agent</span>
          <span class="pipeline-badge pb-live">Live</span>
        </div>
        <div class="pipeline-meta">ElevenLabs proxy pending</div>
        <div class="progress-bar"><div class="progress-fill" style="width:60%"></div></div>
      </div>

      <div class="pipeline-item">
        <div class="pipeline-header">
          <span class="pipeline-name">Email Sequences</span>
          <span class="pipeline-badge pb-building">Building</span>
        </div>
        <div class="pipeline-meta">Phase 2 — not started</div>
        <div class="progress-bar"><div class="progress-fill" style="width:0%"></div></div>
      </div>
    </div>

    <div class="sidebar-divider"></div>

    <div class="panel-section">
      <div class="panel-title"><span>Recent activity</span></div>
      <div class="activity-item">
        <span class="activity-time">Now</span>
        <span class="activity-text"><strong>Command Center</strong> initialized</span>
      </div>
      <div class="activity-item">
        <span class="activity-time">Earlier</span>
        <span class="activity-text"><strong>Lead Gen</strong> workflow executed successfully</span>
      </div>
      <div class="activity-item">
        <span class="activity-time">Earlier</span>
        <span class="activity-text"><strong>Voice Agent</strong> transcription working</span>
      </div>
      <div class="activity-item">
        <span class="activity-time">Earlier</span>
        <span class="activity-text"><strong>Anthropic API</strong> connected</span>
      </div>
      <div class="activity-item">
        <span class="activity-time">Earlier</span>
        <span class="activity-text"><strong>n8n</strong> workflow imported</span>
      </div>
    </div>

    <div class="sidebar-divider"></div>

    <div class="panel-section">
      <div class="panel-title"><span>Quick build</span></div>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <button onclick="quickBuild('email')" style="padding:8px 12px;border-radius:8px;background:var(--surface2);border:1px solid var(--border);color:var(--muted);font-family:inherit;font-size:0.72rem;cursor:pointer;text-align:left;transition:all 0.15s;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)';" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)';">
          + Email sequence agent
        </button>
        <button onclick="quickBuild('linkedin')" style="padding:8px 12px;border-radius:8px;background:var(--surface2);border:1px solid var(--border);color:var(--muted);font-family:inherit;font-size:0.72rem;cursor:pointer;text-align:left;transition:all 0.15s;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)';" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)';">
          + LinkedIn automation agent
        </button>
        <button onclick="quickBuild('calling')" style="padding:8px 12px;border-radius:8px;background:var(--surface2);border:1px solid var(--border);color:var(--muted);font-family:inherit;font-size:0.72rem;cursor:pointer;text-align:left;transition:all 0.15s;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)';" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)';">
          + ElevenLabs calling agent
        </button>
        <button onclick="quickBuild('reporting')" style="padding:8px 12px;border-radius:8px;background:var(--surface2);border:1px solid var(--border);color:var(--muted);font-family:inherit;font-size:0.72rem;cursor:pointer;text-align:left;transition:all 0.15s;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)';" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)';">
          + Daily reporter agent
        </button>
      </div>
    </div>
  </div>

</div>

<!-- SETTINGS MODAL -->
<div class="modal" id="modal">
  <div class="modal-card">
    <h2 class="modal-title">Configure Command Center</h2>
    <p class="modal-sub">Connect your APIs and n8n webhook to activate the full army. Keys stored in session only.</p>

    <div class="field">
      <label>Anthropic API Key</label>
      <input type="password" id="anthropicKey" placeholder="sk-ant-..." />
    </div>
    <div class="field">
      <label>n8n Webhook URL (Command Center)</label>
      <input type="text" id="n8nWebhook" placeholder="https://your-n8n.cloud/webhook/command" />
    </div>
    <div class="field">
      <label>n8n TTS Webhook URL (Voice)</label>
      <input type="text" id="ttsWebhook" placeholder="https://your-n8n.cloud/webhook/tts" />
    </div>
    <div class="field">
      <label>OpenAI API Key (Transcription)</label>
      <input type="password" id="openaiKey" placeholder="sk-..." />
    </div>
    <div class="field">
      <label>ElevenLabs Voice ID (optional)</label>
      <input type="text" id="voiceId" placeholder="Default: Rachel" />
    </div>

    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeSettings()">Cancel</button>
      <button class="btn-save" onclick="saveSettings()">Save & Connect</button>
    </div>
  </div>
</div>

<script>
// ── CONFIG ──────────────────────────────────────────────────────────────────
let cfg = {
  anthropic: '', n8nWebhook: '', ttsWebhook: '',
  openai: '', voiceId: '21m00Tcm4TlvDq8ikWAM'
};
try { const s = localStorage.getItem('cmdCenterCfg'); if(s) cfg = {...cfg,...JSON.parse(s)}; } catch(e){}

// ── CLOCK ───────────────────────────────────────────────────────────────────
function updateClock(){
  const now = new Date();
  document.getElementById('clock').textContent =
    now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false});
}
setInterval(updateClock, 1000);
updateClock();

// ── SETTINGS ────────────────────────────────────────────────────────────────
function openSettings(){
  document.getElementById('anthropicKey').value = cfg.anthropic;
  document.getElementById('n8nWebhook').value = cfg.n8nWebhook;
  document.getElementById('ttsWebhook').value = cfg.ttsWebhook;
  document.getElementById('openaiKey').value = cfg.openai;
  document.getElementById('voiceId').value = cfg.voiceId === '21m00Tcm4TlvDq8ikWAM' ? '' : cfg.voiceId;
  document.getElementById('modal').classList.add('open');
}
function closeSettings(){ document.getElementById('modal').classList.remove('open'); }
function saveSettings(){
  cfg.anthropic = document.getElementById('anthropicKey').value.trim();
  cfg.n8nWebhook = document.getElementById('n8nWebhook').value.trim();
  cfg.ttsWebhook = document.getElementById('ttsWebhook').value.trim();
  cfg.openai = document.getElementById('openaiKey').value.trim();
  const vid = document.getElementById('voiceId').value.trim();
  cfg.voiceId = vid || '21m00Tcm4TlvDq8ikWAM';
  try { localStorage.setItem('cmdCenterCfg', JSON.stringify(cfg)); } catch(e){}
  closeSettings();
  addMessage('cmd', 'Command Center', 'Configuration saved. APIs connected.', 'System');
}

// ── SIDEBAR ─────────────────────────────────────────────────────────────────
function selectAgent(el, name){
  document.querySelectorAll('.agent-item').forEach(i => i.classList.remove('active'));
  el.classList.add('active');
  addMessage('cmd', 'Command Center', `${name} selected. This agent is standing by for tasks.`, 'Agent');
}

// ── MESSAGES ────────────────────────────────────────────────────────────────
function now(){
  return new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',hour12:true});
}

function addMessage(type, name, content, badge=''){
  const messages = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = 'msg' + (type === 'you' ? ' you' : '');

  const avatarClass = type === 'you' ? 'avatar-you' : type === 'agent' ? 'avatar-agent' : 'avatar-cmd';
  const avatarText = type === 'you' ? 'YOU' : type === 'agent' ? 'AG' : 'CC';
  const badgeClass = type === 'you' ? 'badge-you' : type === 'agent' ? 'badge-agent' : 'badge-cmd';

  div.innerHTML = `
    <div class="msg-avatar ${avatarClass}">${avatarText}</div>
    <div class="msg-body">
      <div class="msg-header">
        <span class="msg-name">${name}</span>
        ${badge ? `<span class="msg-badge ${badgeClass}">${badge}</span>` : ''}
        <span class="msg-time">${now()}</span>
      </div>
      <div class="msg-text">${content}</div>
    </div>
  `;
  messages.appendChild(div);
  messages.scrollTop = messages.scrollHeight;
}

function addTyping(){
  const messages = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = 'msg';
  div.id = 'typing-indicator';
  div.innerHTML = `
    <div class="msg-avatar avatar-cmd">CC</div>
    <div class="msg-body">
      <div class="msg-header"><span class="msg-name">Command Center</span></div>
      <div class="msg-text"><div class="typing"><span></span><span></span><span></span></div></div>
    </div>
  `;
  messages.appendChild(div);
  messages.scrollTop = messages.scrollHeight;
}

function removeTyping(){
  const t = document.getElementById('typing-indicator');
  if(t) t.remove();
}

// ── COMMAND PROCESSING ───────────────────────────────────────────────────────
const SYSTEM_PROMPT = `You are the Command Center — the brain of an autonomous AI agent army. You manage 11 specialized agents across 4 squads:

BUILD SQUAD: Architect (designs n8n workflows), Builder (generates workflow JSON), Debugger (fixes errors)
OPS SQUAD: Lead Finder (Apollo/Clay/Hunter), Scorer (0-100 qualification), Copywriter (Claude API for all channels), CRM Agent (Google Sheets/Airtable)
OUTREACH SQUAD: Email Agent (Instantly/Smartlead), LinkedIn Agent (Phantombuster/Expandi), Voice Agent (ElevenLabs), Scheduler (Cal.com)
SUPPORT SQUAD: Watchdog (monitors agents), Reporter (daily digests), Optimizer (A/B tests), Ad Agent (Meta/Google)

When the user gives you a command:
1. Identify which agents are needed
2. Create a clear task plan
3. Respond in a direct, military-ops style — no fluff
4. Format your response with a brief assessment, then a task breakdown using this format:
   [DISPATCHING: AgentName → task]
5. Keep responses under 150 words
6. If asked about status, give a crisp update
7. If a task requires an API not yet configured, mention what's needed

The user's name is Jenale. She is the General. Address her accordingly.`;

async function processCommand(cmd) {
  addTyping();
  document.getElementById('sendBtn').disabled = true;

  try {
    if (!cfg.anthropic) {
      removeTyping();
      addMessage('cmd', 'Command Center', 'No Anthropic API key configured. Click <strong>Configure</strong> in the top right to add your keys, General.', 'System');
      return;
    }

    // Route through n8n if webhook URL is configured, otherwise direct to Claude
    let reply;
    if (cfg.n8nWebhook) {
      const res = await fetch(cfg.n8nWebhook, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ command: cmd, anthropic_key: cfg.anthropic })
      });
      if (!res.ok) throw new Error('n8n webhook failed');
      const data = await res.json();
      reply = data.reply || data.message || data.content || JSON.stringify(data);
    } else {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': cfg.anthropic,
          'anthropic-version': '2023-06-01',
          'anthropic-dangerous-direct-browser-access': 'true'
        },
        body: JSON.stringify({
          model: 'claude-sonnet-4-5',
          max_tokens: 600,
          system: SYSTEM_PROMPT,
          messages: [{ role: 'user', content: cmd }]
        })
      });
      const data = await res.json();
      if (!res.ok) {
        removeTyping();
        addMessage('cmd', 'Command Center', `Error: ${data.error?.message || 'API call failed'}`, 'Error');
        return;
      }
      reply = data.content[0].text;
    }
    removeTyping();
    addMessage('cmd', 'Command Center', reply.replace(/\n/g,'<br>').replace(/\[([^\]]+)\]/g,'<span style="color:var(--accent);font-family:\'JetBrains Mono\',monospace;font-size:0.8rem;">[$1]</span>'), 'Dispatch');

    // Add to activity log
    addActivity(`Command processed: "${cmd.substring(0,40)}${cmd.length > 40 ? '...' : ''}"`);

  } catch(err) {
    removeTyping();
    addMessage('cmd', 'Command Center', `Connection error: ${err.message}`, 'Error');
  }

  document.getElementById('sendBtn').disabled = false;
}

function addActivity(text){
  const panel = document.querySelector('.right-panel .panel-section:nth-child(3)');
  const firstItem = panel?.querySelector('.activity-item');
  if(!firstItem) return;
  const div = document.createElement('div');
  div.className = 'activity-item';
  div.innerHTML = `<span class="activity-time">${now()}</span><span class="activity-text">${text}</span>`;
  firstItem.parentNode.insertBefore(div, firstItem);
}

// ── SEND ─────────────────────────────────────────────────────────────────────
async function sendCommand(){
  const input = document.getElementById('cmdInput');
  const cmd = input.value.trim();
  if(!cmd) return;

  addMessage('you', 'You', cmd, 'Command');
  input.value = '';
  input.style.height = 'auto';

  await processCommand(cmd);
}

function handleKey(e){
  if(e.key === 'Enter' && !e.shiftKey){
    e.preventDefault();
    sendCommand();
  }
}

function setCmd(text){
  const input = document.getElementById('cmdInput');
  input.value = text;
  input.focus();
}

function autoResize(el){
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

// ── QUICK BUILD ───────────────────────────────────────────────────────────────
function quickBuild(type){
  const cmds = {
    email: 'Build me an email sequence agent using Instantly that sends the Claude-written copy automatically',
    linkedin: 'Build me a LinkedIn automation agent using Phantombuster that sends connection requests automatically',
    calling: 'Build me an ElevenLabs calling agent that calls HOT leads automatically within 5 minutes',
    reporting: 'Build me a daily reporter agent that sends a pipeline summary every morning at 7am'
  };
  setCmd(cmds[type]);
  document.getElementById('cmdInput').focus();
}

// ── VOICE ─────────────────────────────────────────────────────────────────────
let mediaRecorder, audioChunks = [], isRecording = false, stream;

async function toggleVoice(){
  if(isRecording){ stopVoice(); return; }
  try {
    stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    mediaRecorder = new MediaRecorder(stream);
    audioChunks = [];
    mediaRecorder.ondataavailable = e => audioChunks.push(e.data);
    mediaRecorder.onstop = handleVoiceEnd;
    mediaRecorder.start();
    isRecording = true;
    document.getElementById('micBtn').classList.add('recording');
    document.getElementById('voiceTopBtn').classList.add('recording');
    addMessage('cmd', 'Command Center', 'Listening... Release mic to send command.', 'Voice');
  } catch(err) {
    addMessage('cmd', 'Command Center', 'Mic access denied. Check browser permissions.', 'Error');
  }
}

function stopVoice(){
  if(!isRecording) return;
  isRecording = false;
  document.getElementById('micBtn').classList.remove('recording');
  document.getElementById('voiceTopBtn').classList.remove('recording');
  if(mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
  if(stream) stream.getTracks().forEach(t => t.stop());
}

async function handleVoiceEnd(){
  if(!cfg.openai){
    addMessage('cmd', 'Command Center', 'No OpenAI key configured for transcription. Add it in Configure.', 'Error');
    return;
  }
  addTyping();
  try {
    const blob = new Blob(audioChunks, { type:'audio/webm' });
    const form = new FormData();
    form.append('file', blob, 'audio.webm');
    form.append('model', 'whisper-1');
    const res = await fetch('https://api.openai.com/v1/audio/transcriptions', {
      method:'POST', headers:{'Authorization':`Bearer ${cfg.openai}`}, body:form
    });
    const data = await res.json();
    removeTyping();
    if(data.text){
      document.getElementById('cmdInput').value = data.text;
      await sendCommand();
    }
  } catch(err) {
    removeTyping();
    addMessage('cmd', 'Command Center', 'Transcription failed: ' + err.message, 'Error');
  }
}

// Open settings on first load if no key
if(!cfg.anthropic) setTimeout(openSettings, 600);
</script>
</body>
</html>
[InternetShortcut]

